# =============================================================================
# Conduit Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- App ---
APP_NAME=Conduit
APP_ENV=development
DEBUG=false
API_HOST=127.0.0.1
API_PORT=8000

# --- API Authentication ---
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CONDUIT_API_KEY=CHANGE-ME-generate-a-random-key

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://conduit:conduit@localhost:5432/conduit

# --- Redis (optional, falls back to in-memory rate limiting) ---
REDIS_URL=redis://localhost:6379/0

# --- Wallet Backend ---
# "lnd" = direct gRPC to your LND node
# "nwc" = Nostr Wallet Connect (Alby, Primal, Zeus, etc.)
# "auto" = use NWC if connection string is set, else LND
WALLET_BACKEND=auto

# --- NWC (Nostr Wallet Connect) ---
# Paste your connection string from your wallet app (e.g. Alby)
# NWC_CONNECTION_STRING=nostr+walletconnect://...

# --- LND Node (only needed if WALLET_BACKEND=lnd) ---
LND_HOST=localhost
LND_GRPC_PORT=10009
LND_REST_PORT=8080
LND_TLS_CERT_PATH=~/.lnd/tls.cert
LND_MACAROON_PATH=~/.lnd/data/chain/bitcoin/regtest/admin.macaroon
# Set to "mainnet", "testnet", or "regtest"
LND_NETWORK=regtest

# --- L402 Auth ---
L402_ENABLED=false
# Generate a unique secret: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
L402_SECRET_KEY=CHANGE-ME-generate-a-random-secret
L402_TOKEN_EXPIRY_SECONDS=3600
L402_DEFAULT_PRICE_SATS=10

# --- Fees ---
TRANSACTION_FEE_PERCENT=1.5

# --- Spending Limits (sats, 0 = unlimited) ---
SPENDING_LIMIT_PER_PAYMENT_SATS=10000
SPENDING_LIMIT_HOURLY_SATS=50000
SPENDING_LIMIT_DAILY_SATS=200000
SPENDING_CONFIRM_ABOVE_SATS=1000

# --- CORS ---
# Comma-separated origins. Never use "*" in production.
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Nostr (optional) ---
# NOSTR_PRIVATE_KEY=nsec1...
# NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol

# --- Federation (shared reputation + skill catalog) ---
# Opt-out, default true. When enabled, a confirmed execution mints a provider
# payer-binding and ratings are PUBLISHED to public Nostr relays + cached, so
# discovery can show cross-node scores. Also (Federation #2) pulls verified remote
# SKILL listings from relays + peers into discovery, origin-tagged; remote skills are
# not executable yet (cross-node execution is Federation #3).
# Privacy: publishing exposes the consumer's payment graph (skill_id +
# payment_hash + the rater's pseudonymous Nostr pubkey + score) on public relays.
# Set to false to keep ratings + catalog local-only.
# FEDERATION_ENABLED=true
# Comma-separated peer base URLs to pull cached attestations + skill listings from
# (https only; SSRF-guarded). Public serve endpoints live under /api/v1/federation.
# FEDERATION_PEERS=https://peer-a.example,https://peer-b.example
# How often the background loop refreshes the reputation + catalog caches (minutes).
# FEDERATION_REFRESH_INTERVAL_MINUTES=30
